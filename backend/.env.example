# ── Data Pipeline Copilot — LLM provider config ──────────────────────────────
# Choose ONE provider. Ollama is local, free, and private (recommended for dev).

LLM_PROVIDER=ollama

# Ollama (https://ollama.com) — run: ollama pull qwen2.5-coder:14b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:14b

# Google Gemini free tier — key from https://aistudio.google.com
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Groq free tier — key from https://console.groq.com
# LLM_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter free models — key from https://openrouter.ai
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Server ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
